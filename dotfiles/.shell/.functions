# delete backup files
bakclean () {
  find . -name "*.*.bak" -type f -delete
  find . -name "*.bak" -type f -delete
}

# cd into whatever is the forefront Finder window
cdf () {
  local path=$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')
  echo "$path"
  cd "$path"
}

# iterate over sub-directories and pull git repositories
rgp () {
  find . -name ".git" -type d | sed 's/\/.git//' | xargs -P10 -I{} sh -c 'git -C {} fetch --all && git -C {} pull'
}

# load `.env` file from a filename passed as an argument
loadenv () {
  while read line; do
    if [ "${line:0:1}" = '#' ]; then
      continue  # ignore comments
    fi
    export $line > /dev/null
  done < "$1"
  echo "Loaded!"
}

# show pretty `man` page
man () {
  env \
    LESS_TERMCAP_mb=$(printf '\e[1;31m') \
    LESS_TERMCAP_md=$(printf '\e[1;31m') \
    LESS_TERMCAP_me=$(printf '\e[0m') \
    LESS_TERMCAP_se=$(printf '\e[0m') \
    LESS_TERMCAP_so=$(printf '\e[1;44;33m') \
    LESS_TERMCAP_ue=$(printf '\e[0m') \
    LESS_TERMCAP_us=$(printf '\e[1;32m') \
      man "$@"
}

# activate environment via `pdm shell`
pdm () {
    local command=$1
    if [[ $command == "shell" ]]; then
        eval $(pdm venv activate)
    else
        command pdm $@
    fi
}

# delete Python cache
pyclean () {
  find . \
    | grep -E '(__pycache__|\.(mypy_)?cache|\.hypothesis\.py[cod]|\.(pytest_)?cache|\.ropeproject|\.(ruff_)?cache|\.(ipynb_)?checkpoints|.coverage|coverage.xml$)' \
    | xargs rm -rf
}

# find file and open it
run_find_files () { find_files; }
zle -N run_find_files

# find a match in files and open it
run_find_in_files () { find_in_files; }
zle -N run_find_in_files
