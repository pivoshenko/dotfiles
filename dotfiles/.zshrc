# =============================================================================================
# oh-my-zsh
# =============================================================================================

export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME=""
ZSH_COLORIZE_CHROMA_FORMATTER=terminal256

# list of plugins
plugins=(
  gitfast
  gh
  safe-paste
)

source $ZSH/oh-my-zsh.sh

# =============================================================================================
# zplug
# =============================================================================================

export ZPLUG_HOME=$(brew --prefix)/opt/zplug
source $ZPLUG_HOME/init.zsh

source "$HOME/.zplugrc"

# =============================================================================================
# Shell parts
# =============================================================================================

for file in $HOME/.shell/*; do
  source "$file"
done

# =============================================================================================
# System information
# =============================================================================================

neofetch
